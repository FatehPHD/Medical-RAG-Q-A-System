```gitignore
# Python-generated files
__pycache__/
*.py[cod]
*$py.class
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Environment variables / secrets
.env
.env.local
*.env

# ChromaDB / generated vector store
data/vector_store/
chroma/
*.sqlite3
*.db

# Streamlit
.streamlit/secrets.toml

# Logs
*.log

# OS / editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Cache files
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
```
